# ============================================
# Virgil Configuration
# ============================================

# Workspace and local state
VIRGIL_WORKSPACE=.
# VIRGIL_DB_PATH=.virgil/virgil.db
# DEBUG=1

# ============================================
# LLM Backend Selection
# ============================================
# Choose ONE profile by uncommenting exactly one LLM_PROVIDER block.
# Values below are examples; keep them aligned with your local .env and models.

# --- Profile A: Ollama (default, local) ---
LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
VIRGIL_WATCHDOG_CONTEXT_LIMIT=12000

# --- Profile B: llama.cpp (OpenAI-compatible local) ---
# LLM_PROVIDER=openai
# OPENAI_API_BASE=http://127.0.0.1:8081/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=qwen
# OPENAI_TEMPERATURE=0.3
# OPENAI_TOP_P=0.9
# OPENAI_MAX_TOKENS=8192
# OPENAI_STREAM=true
# VIRGIL_WATCHDOG_CONTEXT_LIMIT=12000

# --- Profile C: OpenAI API (cloud, paid) ---
# LLM_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...your-key-here
# OPENAI_MODEL=gpt-5-mini
# OPENAI_TEMPERATURE=0.2
# OPENAI_TOP_P=0.9
# VIRGIL_WATCHDOG_CONTEXT_LIMIT=100000

# ============================================
# Agent Behavior
# ============================================
# Default timeout for normal requests and planning
# VIRGIL_AGENT_TIMEOUT_MINUTES=5
# Default timeout for executing generated TODO lists
# VIRGIL_RUN_TIMEOUT_MINUTES=30
# Override /debug-context input path. Relative paths are resolved from workspace root.
# Default lookup order: .vscode/debug-context.json, then .virgil/debug-context.json.
# VIRGIL_DEBUG_CONTEXT_PATH=.vscode/debug-context.json

# ============================================
# Web Fetch Tool (fetch_docs)
# ============================================
# Add a corporate or custom CA bundle for fetch_docs HTTPS requests.
# VIRGIL_FETCH_CA_BUNDLE=/path/to/company-ca-bundle.pem
# Override User-Agent for sites that block default clients.
# VIRGIL_FETCH_USER_AGENT=Mozilla/5.0
# Disable TLS verification for local debugging only.
# VIRGIL_FETCH_INSECURE_SKIP_VERIFY=false

# ============================================
# Prompt Customization
# ============================================
# Append local environment instructions to the system prompt at startup.
# VIRGIL_PROMPT_APPEND=/home/user/.virgil/prompt.md
# Load session memory notes from a file. Defaults to .virgil/remember.md.
# VIRGIL_REMEMBER_FILE=/home/user/.virgil/remember.md
# Restrict mutating file tools to these paths (comma-separated). Directories should end with /.
# VIRGIL_EDIT_ALLOWLIST=src/MAE_testcase/,src/AE_pytorch.py,src/MAE_pytorch.py

# ============================================
# Watchdog
# ============================================
# VIRGIL_WATCHDOG_MAX_REPEAT=3
# VIRGIL_WATCHDOG_MAX_EMPTY=2

# ============================================
# Shell Command Tool (run_command)
# ============================================
# Auto-allow these command prefixes (comma-separated)
VIRGIL_RUN_AUTO_ALLOW=go test,go build,go vet,git status,git diff,ls,pwd
# Deny these patterns (comma-separated)
VIRGIL_RUN_DENY=rm -rf,sudo,git push,curl,wget
# Default action for non-listed commands: confirm / auto / deny
VIRGIL_RUN_DEFAULT=confirm
# Allow execution outside workspace root
VIRGIL_RUN_ALLOW_OUTSIDE_WORKSPACE=false
